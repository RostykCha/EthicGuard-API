# EthicGuard-API configuration
# Copy to .env for local dev. NEVER commit .env.

# HTTP
ETHICGUARD_HTTP_ADDR=:8080
ETHICGUARD_LOG_LEVEL=info
ETHICGUARD_ENV=dev

# Postgres
ETHICGUARD_DATABASE_URL=postgres://ethicguard:ethicguard@localhost:5432/ethicguard?sslmode=disable

# Claude / Anthropic
# Default analyzer model: Claude Sonnet 4.6.
ETHICGUARD_ANTHROPIC_API_KEY=
ETHICGUARD_ANTHROPIC_MODEL=claude-sonnet-4-6
ETHICGUARD_ANTHROPIC_MODEL_HEAVY=claude-opus-4-6

# Async workers
ETHICGUARD_WORKER_CONCURRENCY=4

# Forge JWT verification: accepted audience for incoming tokens.
ETHICGUARD_JWT_AUDIENCE=ethicguard-api
